# ================================================================
# .env.example — Server environment variables template
# Copy to .env and fill in values
# ================================================================

# MySQL Database (use Railway MySQL plugin variables)
DB_HOST=your-railway-mysql-host
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-db-password
DB_NAME=railway

# Express Server
PORT=5000

# Media storage directory (relative to server root)
MEDIA_PATH=./media

# CORS - set to your Vercel frontend URL in production
CORS_ORIGIN=https://your-app.vercel.app

# Admin seed credentials (only used during initial database seeding)
ADMIN_EMAIL=admin@srinivasa.com
ADMIN_PASSWORD=admin123
